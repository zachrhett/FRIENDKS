"use strict";

(function () {

    const listeners = new Map();
    const history = [];

    function on(eventName, callback) {
        if (!eventName || typeof callback !== "function") return false;

        if (!listeners.has(eventName)) {
            listeners.set(eventName, new Set());
        }

        listeners.get(eventName).add(callback);
        return true;
    }

    function off(eventName, callback) {
        if (!listeners.has(eventName)) return false;

        listeners.get(eventName).delete(callback);

        if (listeners.get(eventName).size === 0) {
            listeners.delete(eventName);
        }

        return true;
    }

    function once(eventName, callback) {
        if (!eventName || typeof callback !== "function") return false;

        const wrapper = function (payload) {
            off(eventName, wrapper);
            callback(payload);
        };

        return on(eventName, wrapper);
    }

    function emit(eventName, payload = {}) {
        if (!eventName) return false;

        const eventRecord = {
            eventName,
            payload,
            timestamp: new Date().toISOString()
        };

        history.push(eventRecord);

        if (!listeners.has(eventName)) return true;

        listeners.get(eventName).forEach(callback => {
            try {
                callback(payload, eventRecord);
            } catch (error) {
                console.error("[FRIEND EventBus] listener error:", eventName, error);
            }
        });

        return true;
    }

    function clear(eventName) {
        if (eventName) {
            listeners.delete(eventName);
            return true;
        }

        listeners.clear();
        return true;
    }

    function listenerCount(eventName) {
        if (eventName) {
            return listeners.has(eventName) ? listeners.get(eventName).size : 0;
        }

        let total = 0;

        listeners.forEach(set => {
            total += set.size;
        });

        return total;
    }

    function getEvents() {
        return Array.from(listeners.keys());
    }

    function getHistory() {
        return history.slice();
    }

    function resetHistory() {
        history.length = 0;
        return true;
    }

    window.FRIENDEventBus = {
        on,
        off,
        once,
        emit,
        clear,
        listenerCount,
        getEvents,
        getHistory,
        resetHistory
    };

    console.log("[FRIEND] event-bus.js loaded");

})();
